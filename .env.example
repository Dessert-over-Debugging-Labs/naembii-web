# Figma 쓰기형 MCP(플러그인 브리지) 채널
# Figma 플러그인(TalkToFigma)에서 "Connect" 시 표시되는 채널 ID로 교체.
FIGMA_CHANNEL=REPLACE_WITH_YOUR_FIGMA_CHANNEL

# 베타 신청/피드백 수집 저장소
# 1) Google Form 응답으로 저장할 때
# formResponse URL과 entry ID 매핑을 넣는다. 같은 폼에 kind 필드를 두면 beta/recipe/feedback을 구분할 수 있다.
NAEMBI_BETA_GOOGLE_FORM_URL=https://docs.google.com/forms/d/e/FORM_ID/formResponse
NAEMBI_BETA_GOOGLE_FORM_FIELDS={"kind":"entry.111111","email":"entry.222222","name":"entry.333333","profile":"entry.444444","note":"entry.555555","type":"entry.666666","message":"entry.777777","recipe":"entry.888888","source":"entry.999999","screen":"entry.131313","page":"entry.101010","createdAt":"entry.121212"}

# 베타/피드백 폼을 분리할 때는 아래 두 값을 사용한다.
# NAEMBI_BETA_GOOGLE_FORM_FIELDS_BETA={"kind":"entry.111111","email":"entry.222222","name":"entry.333333","profile":"entry.444444","note":"entry.555555","source":"entry.999999","screen":"entry.131313","page":"entry.101010","createdAt":"entry.121212"}
# NAEMBI_BETA_GOOGLE_FORM_FIELDS_FEEDBACK={"kind":"entry.111111","type":"entry.666666","email":"entry.222222","message":"entry.777777","recipe":"entry.888888","screen":"entry.131313","source":"entry.999999","page":"entry.101010","createdAt":"entry.121212"}

# 2) GitHub Issue로 저장할 때
NAEMBI_BETA_GITHUB_REPO=owner/repo
NAEMBI_BETA_GITHUB_TOKEN=GITHUB_TOKEN_VALUE
NAEMBI_BETA_GITHUB_LABELS=naembi-beta

# 3) 또는 Make/Zapier/Slack/Google Apps Script webhook으로 저장할 때
NAEMBI_BETA_WEBHOOK_URL=https://example.com/webhook
