# Figma 쓰기형 MCP(플러그인 브리지) 채널
# Figma 플러그인(TalkToFigma)에서 "Connect" 시 표시되는 채널 ID로 교체.
FIGMA_CHANNEL=REPLACE_WITH_YOUR_FIGMA_CHANNEL

# 베타 신청/피드백 수집 저장소
# 1) Google Form 응답으로 저장할 때
# formResponse URL과 entry ID 매핑을 넣는다. 같은 폼에 kind 필드를 두면 beta/recipe/feedback을 구분할 수 있다.
NAEMBI_BETA_GOOGLE_FORM_URL=https://docs.google.com/forms/d/e/FORM_ID/formResponse
NAEMBI_BETA_GOOGLE_FORM_FIELDS={"kind":"entry.111111","requestId":"entry.141414","email":"entry.222222","name":"entry.333333","profile":"entry.444444","note":"entry.555555","type":"entry.666666","message":"entry.777777","recipe":"entry.888888","source":"entry.999999","screen":"entry.131313","page":"entry.101010","createdAt":"entry.121212"}

# 베타/피드백 폼을 분리할 때는 아래 두 값을 사용한다.
# NAEMBI_BETA_GOOGLE_FORM_FIELDS_BETA={"kind":"entry.111111","requestId":"entry.141414","email":"entry.222222","name":"entry.333333","profile":"entry.444444","note":"entry.555555","source":"entry.999999","screen":"entry.131313","page":"entry.101010","createdAt":"entry.121212"}
# NAEMBI_BETA_GOOGLE_FORM_FIELDS_FEEDBACK={"kind":"entry.111111","requestId":"entry.141414","type":"entry.666666","email":"entry.222222","message":"entry.777777","recipe":"entry.888888","screen":"entry.131313","source":"entry.999999","page":"entry.101010","createdAt":"entry.121212"}

# 2) GitHub Issue로 저장할 때
NAEMBI_BETA_GITHUB_REPO=owner/repo
NAEMBI_BETA_GITHUB_TOKEN=GITHUB_TOKEN_VALUE
NAEMBI_BETA_GITHUB_LABELS=naembi-beta

# 3) 또는 Make/Zapier/Slack/Google Apps Script webhook으로 저장할 때
NAEMBI_BETA_WEBHOOK_URL=https://example.com/webhook

# 4) Slack 알림과 Google Sheet 반영완료 자동 체크
# Slack Incoming Webhook URL을 넣으면 제출 도착 알림을 받는다.
NAEMBI_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Apps Script Web App URL과 토큰을 넣으면 Slack 알림의 "반영완료 체크" 버튼이 Google Sheet 체크박스를 갱신한다.
NAEMBI_BETA_COMPLETION_URL=https://script.google.com/macros/s/DEPLOYMENT_ID/exec
NAEMBI_BETA_COMPLETION_TOKEN=GENERATED_OPERATION_TOKEN

# Mixpanel 행동 분석
# Project Token만 넣는다. API Secret, Service Account Secret은 브라우저 공개 설정에 넣지 않는다.
NAEMBI_MIXPANEL_TOKEN=MIXPANEL_PROJECT_TOKEN
NAEMBI_MIXPANEL_ENABLED=true
NAEMBI_MIXPANEL_DEBUG=false

# Gemini Live 실험 기능
# 브라우저에는 원본 키를 노출하지 않는다. /api/gemini-live-token이 1회용 Live 토큰만 발급한다.
NAEMBI_GEMINI_API_KEY=GOOGLE_AI_STUDIO_API_KEY
NAEMBI_GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
NAEMBI_GEMINI_LIVE_TOKEN_TTL_MINUTES=30
NAEMBI_GEMINI_LIVE_NEW_SESSION_SECONDS=60

# Langfuse 대화 텍스트 기록 (서버 전용, 브라우저에 노출하지 않는다)
# pk-lf/sk-lf 한 쌍은 특정 Langfuse 프로젝트에 연결된 키이다.
LANGFUSE_PUBLIC_KEY=pk-lf-REPLACE_ME
LANGFUSE_SECRET_KEY=sk-lf-REPLACE_ME
LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com
LANGFUSE_TRACING_ENVIRONMENT=development

# 키가 있으면 기본은 활성화된다. 긴급 중지할 때만 false로 바꾼다.
NAEMBI_LANGFUSE_ENABLED=true
# 배포 시 실제 도메인만 콤마로 나열한다.
NAEMBI_ALLOWED_ORIGINS=http://127.0.0.1:4876,https://naembii-web.vercel.app
